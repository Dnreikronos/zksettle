{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@solana/web3.js": ["./node_modules/@solana/web3.js"],
      "@coral-xyz/anchor": ["./node_modules/@coral-xyz/anchor"]
    }
  },
  "include": ["*.ts", "../lib/*.ts"]
}
